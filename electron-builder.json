{
  "appId": "com.alphapath.app",
  "productName": "AlphaPath",
  "directories": {
    "output": "release"
  },
  "files": [
    "electron-main.cjs",
    "preload.cjs",
    "dist/**/*"
  ],
  "buildDependenciesFromSource": false,
  "nodeGypRebuild": false,
  "npmRebuild": false,
  "publish": {
    "provider": "github",
    "owner": "chriszhaoqk",
    "repo": "AlphaPath"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
    "icon": "dist/pwa-512x512.png",
    "category": "public.app-category.finance"
  },
  "win": {
    "target": ["nsis"],
    "icon": "dist/pwa-512x512.png"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "dist/pwa-512x512.png",
    "category": "Finance"
  }
}
